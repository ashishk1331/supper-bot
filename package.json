{
  "name": "supper-bot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --cwd apps/bot dev",
    "start": "bun run --cwd apps/bot start",
    "typecheck": "bun run --cwd packages/types typecheck && bun run --cwd apps/bot typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:generate": "bun run --cwd apps/bot db:generate",
    "db:migrate": "bun run --cwd apps/bot db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.3",
    "drizzle-kit": "^0.28.0"
  }
}
